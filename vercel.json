{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/api/index.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "includeFiles": [
        "backend/app/**",
        "backend/alembic/**",
        "backend/alembic.ini",
        "backend/requirements.txt"
      ]
    }
  }
}
